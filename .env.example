# LLM provider (OpenRouter is OpenAI-compatible)
OPENROUTER_API_KEY=sk-or-v1-...
LLM_MODEL=openai/gpt-4o-mini
LLM_BASE_URL=https://openrouter.ai/api/v1

# PostgreSQL (matches docker-compose.yml)
PG_HOST=localhost
PG_PORT=1505
PG_USER=hitl
PG_PASSWORD=hitl
PG_DB=hitl_audit
DATABASE_URL=postgresql://hitl:hitl@localhost:1505/hitl_audit

# GitHub auth — the agent shells out to the `gh` CLI for reading + commenting on PRs.
#
# Preferred path: run `gh auth login` once (stored in keyring). Leave GITHUB_TOKEN empty.
# Fallback path: set GITHUB_TOKEN below — `gh` picks it up automatically.
#   Use the fallback only when you can't run `gh auth login` (CI, Docker, shared machine).
#
# To commit the review back to the PR you also need write permission on the target repo
# (collaborator or owner of a fork). Without write permission the graph still completes
# but `node_commit` records `commit_failed` in the audit trail instead of posting.
GITHUB_TOKEN=
